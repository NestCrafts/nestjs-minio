{
  "extends": "@rubiin/tsconfig",
  "compilerOptions": {
    "sourceMap": false,
    "newLine": "lf",
    "module": "nodenext",
    "rootDir": "./src" // no longer inferred from source files (see §1.5)
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/*.spec.ts"
  ]
}
