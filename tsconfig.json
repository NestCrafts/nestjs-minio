{
  "extends": "@rubiin/tsconfig",
  "compilerOptions": {
    "sourceMap": true,
    "newLine": "lf",
    "module": "node16",
    "moduleResolution": "node16",
    "target": "ES2020",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "tests/*.spec.ts"
  ]
}
